# Force LF line endings on files that must run on Linux VM, regardless of host OS.
*.sh        text eol=lf
*.service   text eol=lf
*.conf      text eol=lf
.env*       text eol=lf

# Normalize sources
*.js        text eol=lf
*.json      text eol=lf
*.sql       text eol=lf
*.md        text eol=lf

# Binary
*.db        binary
*.sqlite    binary
