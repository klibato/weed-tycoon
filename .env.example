# Copy to .env (gitignored) and fill in real values.

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# DB
DB_PATH=./data/weedtycoon.db

# Auth - generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_me_with_64_random_hex_chars
JWT_EXPIRES_IN=1h
HMAC_RESPONSE_SECRET=replace_me_too_with_different_random_hex

# Steam Web API
# Get a key at https://steamcommunity.com/dev/apikey
STEAM_API_KEY=your_steam_web_api_key
# App ID once we publish on Steam; placeholder during dev
STEAM_APP_ID=0
# Set to "true" to skip real Steam ticket verification (dev only, accepts any ticket)
STEAM_AUTH_BYPASS=true

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
